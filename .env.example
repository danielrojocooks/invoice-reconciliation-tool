# Copy this file to .env and fill in your values
# Never commit .env to version control

# QuickBooks Online OAuth2
QB_CLIENT_ID=your_client_id
QB_CLIENT_SECRET=your_client_secret
QB_REALM_ID=your_realm_id
QB_REDIRECT_URI=http://localhost:8080/callback

# QB token exchange (used by qb_token.py on initial authorization)
# QB_AUTH_CODE is a one-time code obtained from the OAuth2 authorization URL.
# After running qb_token.py, replace the values below with the tokens returned.
QB_AUTH_CODE=your_one_time_auth_code

# QB tokens (written automatically after first auth; update after token exchange)
QB_ACCESS_TOKEN=your_access_token
QB_REFRESH_TOKEN=your_refresh_token

# Gmail OAuth2 (for fetching invoices from email via gmail_fetcher.py)
# Create credentials at https://console.cloud.google.com — Desktop app type
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
